{
    "name": "shell-heredoc",
    "displayName": "shell-heredoc",
    "description": "Highlights and validates JSON / YAML / XML / Python / JavaScript inside shell heredoc blocks",
    "version": "0.3.0",
    "repository": "https://github.com/smithjw/shell-heredoc",
    "publisher": "smithjw",
    "icon": "images/icon.png",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "keywords": [
        "bash",
        "shell",
        "heredoc",
        "json",
        "yaml",
        "yml",
        "xml",
        "python",
        "javascript",
        "validation"
    ],
    "main": "./dist/extension.js",
    "activationEvents": [
        "onLanguage:shellscript"
    ],
    "contributes": {
        "grammars": [
            {
                "scopeName": "shell.heredoc.injections",
                "path": "./syntaxes/shell-heredoc-injections.tmLanguage.json",
                "injectTo": [
                    "source.shell"
                ]
            }
        ],
        "configuration": {
            "title": "Shell Heredoc",
            "properties": {
                "shellHeredoc.validate.json": {
                    "type": "boolean",
                    "default": true,
                    "description": "Validate JSON heredocs."
                },
                "shellHeredoc.validate.yaml": {
                    "type": "boolean",
                    "default": true,
                    "description": "Validate YAML/YML heredocs."
                },
                "shellHeredoc.validate.xml": {
                    "type": "boolean",
                    "default": true,
                    "description": "Validate XML and PLIST heredocs."
                },
                "shellHeredoc.validate.python": {
                    "type": "boolean",
                    "default": true,
                    "description": "Validate Python heredocs."
                },
                "shellHeredoc.validate.javascript": {
                    "type": "boolean",
                    "default": true,
                    "description": "Validate JavaScript heredocs."
                },
                "shellHeredoc.maxBytes": {
                    "type": "number",
                    "default": 200000,
                    "description": "Skip validation for large heredocs (bytes)."
                }
            }
        },
        "commands": [
            {
                "command": "shellHeredoc.revalidateCurrent",
                "title": "Shell Heredoc: Revalidate Current File"
            }
        ]
    },
    "scripts": {
        "build": "node scripts/build-grammar.mjs && esbuild src/extension.js --bundle --platform=node --format=cjs --target=node18 --external:vscode --main-fields=module,main --sourcemap --outfile=dist/extension.js",
        "dev": "esbuild src/extension.js --bundle --platform=node --format=cjs --target=node18 --external:vscode --main-fields=module,main --watch=forever --sourcemap --outfile=dist/extension.js",
        "vscode:prepublish": "pnpm run build",
        "smoke": "node scripts/smoke.js",
        "package": "rm -rf node_modules dist && pnpm install --frozen-lockfile && pnpm run build && pnpm run smoke && vsce package --no-dependencies",
        "publish": "rm -rf node_modules dist && pnpm install --frozen-lockfile && pnpm run build && pnpm run smoke && vsce publish --no-dependencies",
        "test": "mocha --recursive test",
        "clean": "rm -rf dist *.vsix"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@vscode/vsce": "^3.7.1",
        "@zzzen/pyright-internal": "1.2.0-dev.20251207",
        "acorn": "^8.17.0",
        "assert": "^2.1.0",
        "esbuild": "^0.27.2",
        "fast-xml-parser": "^5.3.4",
        "js-yaml": "^4.1.1",
        "mocha": "^11.7.5",
        "vscode-json-languageservice": "^5.7.1",
        "vscode-languageserver-textdocument": "^1.0.12"
    },
    "packageManager": "pnpm@10.16.1"
}
